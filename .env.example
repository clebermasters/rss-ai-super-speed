RSS_API_BASE_URL=
RSS_API_TOKEN=
TERRAFORM_STATE_BUCKET=
TERRAFORM_STATE_KEY=rss-ai/terraform.tfstate
TERRAFORM_STATE_REGION=us-east-1
DEFAULT_LLM_PROVIDER=openai_compatible
DEFAULT_AI_MODEL=gpt-5.4
DEFAULT_CODEX_MODEL=gpt-5.4
DEFAULT_BROWSER_BYPASS_ENABLED=true

OPENAI_API_KEY=
MINIMAX_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
AI_MODEL=gpt-5.4
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TTS_API_BASE=https://api.openai.com/v1
OPENAI_TTS_MODEL=gpt-4o-mini-tts-2025-12-15
OPENAI_TTS_VOICE=marin
OPENAI_CODEX_MODEL=gpt-5.4
OPENAI_CODEX_CLIENT_VERSION=0.118.0

S3_TTS_CACHE_EXPIRATION_DAYS=30
S3_BROWSER_RESULTS_EXPIRATION_DAYS=7
S3_CACHE_NONCURRENT_EXPIRATION_DAYS=1

WEB_DOMAIN_NAME=rss.bitslovers.com
# Keep 0 for normal static hosting. If set to 1, deploy_web_app.sh embeds RSS_API_TOKEN in public config.json.
WEB_EMBED_API_TOKEN=0
WEB_THEME=warm
